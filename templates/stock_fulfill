<!DOCTYPE html>
<html>
<head>
    <title>STOCK FULFILLMENT BY PROCUREMENT TEAM</title>

    <!-- Bootstrap -->
    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/css/bootstrap.min.css" rel="stylesheet">

    <style>
        body {
            font-family: 'Segoe UI', sans-serif;
            background: linear-gradient(135deg, #667eea, #764ba2);
            margin: 0;
            padding: 20px;
        }

        /* 🔥 TOP BAR */
        .top-bar {
            display: flex;
            justify-content: space-between;
            align-items: center;
            padding: 12px 25px;
            background: rgba(0,0,0,0.3);
            border-radius: 10px;
            margin-bottom: 20px;
            color: white;
        }

        .top-bar .btn {
            margin-left: 10px;
        }

        h2 {
            text-align: center;
            color: white;
            margin-bottom: 20px;
        }

        /* CARD */
        .card-box {
            background: white;
            padding: 20px;
            border-radius: 15px;
            box-shadow: 0 10px 30px rgba(0,0,0,0.2);
        }

        .table-container {
    max-height: 500px;   /* scroll height */
    overflow-y: auto;
    border: 1px solid #ddd;
}

/* Sticky header */
table thead th {
    position: sticky;
    top: 0;
    background: #343a40;
    color: white;
    z-index: 2;
}

        /* TABLE */
        .table thead {
            background: #667eea;
            color: white;
        }

        .table tbody tr:hover {
            background: #eef1ff;
            transition: 0.2s;
        }

        .table tbody tr:nth-child(even) {
            background: #fafbff;
        }

        /* Highlight condition */
        .highlight-row {
            background: #ffeeba !important;
        }

        /* Button */
        .btn-fulfill {
            background: #28a745;
            color: white;
            border-radius: 6px;
            padding: 6px 12px;
            font-size: 14px;
        }

        .btn-fulfill:hover {
            background: #218838;
        }

        /* FORM */
        .form-box {
            background: white;
            padding: 25px;
            margin-top: 30px;
            border-radius: 15px;
            box-shadow: 0 10px 25px rgba(0,0,0,0.2);
        }

        input, select {
            width: 100%;
            padding: 10px;
            margin-bottom: 10px;
            border-radius: 8px;
            border: 1px solid #ccc;
        }

        button {
            padding: 10px 20px;
            background: linear-gradient(135deg, #667eea, #764ba2);
            color: white;
            border: none;
            border-radius: 8px;
        }
    </style>
</head>

<body>

<!-- 🔥 TOP BAR -->
<div class="top-bar">
    <div>
        
    </div>

    <div>
        <a href="/home">
            <button class="btn btn-primary btn-sm">🏠 Home</button>
        </a>

        <a href="/logout">
            <button class="btn btn-danger btn-sm">Logout</button>
        </a>
    </div>
</div>

<h2>📦 STOCK FULFILLMENT BY PROCUREMENT TEAM - {{ user }}</h2>

<div class="card p-3 mb-3">

<form method="GET" action="/stock_fulfill">

    <div class="row g-2">

        <!-- UID -->
        <div class="col-md-3">
            <label>Filter by UID</label>
            <select name="uid" class="form-select">
                <option value="All">All</option>
                {% for u in uids %}
                <option value="{{ u }}">{{ u }}</option>
                {% endfor %}
            </select>
        </div>

        <!-- SUBID -->
        <div class="col-md-3">
            <label>Filter by SUB ID</label>
            <select name="subid" class="form-select">
                <option value="All">All</option>
                {% for s in subids %}
                <option value="{{ s }}">{{ s }}</option>
                {% endfor %}
            </select>
        </div>

        <!-- BRANCH -->
        <div class="col-md-3">
            <label>Filter by Branch</label>
            <select name="branch" class="form-select">
                <option value="All">All</option>
                {% for b in branches %}
                <option value="{{ b }}">{{ b }}</option>
                {% endfor %}
            </select>
        </div>

        <!-- ITEM -->
        <div class="col-md-3">
            <label>Filter by Item</label>
            <select name="item" class="form-select">
                <option value="All">All</option>
                {% for i in items %}
                <option value="{{ i }}">{{ i }}</option>
                {% endfor %}
            </select>
        </div>

    </div>

    <!-- BUTTON ROW -->
    <div class="row mt-3">
        <div class="col-md-6">
            <button type="submit" class="btn btn-primary w-100">Apply Filter</button>
        </div>

        <div class="col-md-6">
            <a href="/stock_fulfill" class="btn btn-secondary w-100">Reset</a>
        </div>
    </div>

</form>
<div class="card-box">

    <!-- ========================= -->
    <!-- ✅ DATA TABLE -->
    <!-- ========================= -->
    <div class="table-container">

    <table class="table table-bordered text-center align-middle">

        <thead>
            <tr>
                <th>Sr No</th>
                {% for h in headers %}
                    <th>{{ h }}</th>
                {% endfor %}
                <th>Action</th>
            </tr>
        </thead>

        <tbody>
            {% for row in data %}
            <tr>

                <!-- ✅ Serial Number -->
                <td>{{ loop.index }}</td>

                <!-- ✅ Data -->
                {% for cell in row %}
                    <td>{{ cell }}</td>
                {% endfor %}

                <!-- ✅ Action -->
                <td>
                    <a class="btn btn-fulfill" href="/stock_fulfill/{{ row[1] }}/{{ row[2] }}">
                        Fulfill
                    </a>
                </td>

            </tr>
            {% endfor %}
        </tbody>

    </table>

</div>

</div>

<!-- ========================= -->
<!-- ✅ FULFILL FORM -->
<!-- ========================= -->

{% if uid %}

<div class="form-box">

<h4 class="text-center mb-3">Fulfill Requirement</h4>

<form method="POST">

<div class="row">
    <div class="col-md-6">
        <label>UID</label>
        <input type="text" name="uid" value="{{ uid }}" readonly>
    </div>

    <div class="col-md-6">
        <label>Sub ID</label>
        <input type="text" name="subid" value="{{ subid }}" readonly>
    </div>
</div>

<label>Item</label>
<select name="item"><option value="">No Change</option></select>

<label>Brand</label>
<select name="brand"><option value="">No Change</option></select>

<label>Design</label>
<select name="design"><option value="">No Change</option></select>

<label>Type</label>
<select name="type"><option value="">No Change</option></select>

<label>Category</label>
<select name="category"><option value="">No Change</option></select>

<label>Pattern</label>
<select name="pattern"><option value="">No Change</option></select>

<label>Size</label>
<select name="size"><option value="">No Change</option></select>

<br>

<div class="text-center">
    <button type="submit">Save Fulfillment</button>
</div>

</form>

</div>

{% endif %}

</body>
</html>
